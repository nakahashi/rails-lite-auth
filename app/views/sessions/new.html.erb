<h1>ログイン</h1>

<%= form_with url: login_path do |f| %>
  <div>
    <%= f.label :email, "メールアドレス" %>
    <%= f.email_field :email, required: true %>
  </div>
  <div>
    <%= f.label :password, "パスワード" %>
    <%= f.password_field :password, required: true %>
  </div>
  <%= f.submit "ログイン" %>
<% end %>

<%= link_to "新規登録はこちら", signup_path %>
